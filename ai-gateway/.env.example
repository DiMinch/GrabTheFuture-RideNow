PORT=8000
HOST=0.0.0.0
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp # Recommended for Multimodal Live (WebRTC/WebSockets)
BACKEND_SERVER_URL=http://localhost:5000/api
USE_FALLBACK_AGENT=false # Set to true to bypass WebSocket Live and use REST fallback agent (no GPU/heavy setup needed)
GEOVINA_API_KEY= # Optional: API Key for GeoVina (https://geovina.io.vn) to normalize old/merged Vietnamese addresses

