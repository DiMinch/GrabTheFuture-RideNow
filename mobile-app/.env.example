# Backend Express API and WebSocket endpoint
BACKEND_URL=http://localhost:5000

# AI Gateway HTTP and WebSocket endpoint for Gemini Live Stream
AI_GATEWAY_URL=http://localhost:8000
AI_GATEWAY_WS_URL=ws://localhost:8000/api/ai/stream

# Mocks (Useful for emulator/simulator testing where native hardware is restricted)
MOCK_BLE_BEACON=true
MOCK_GPS_MOVEMENT=true
