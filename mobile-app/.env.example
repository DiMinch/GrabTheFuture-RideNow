# Backend Express API and WebSocket endpoint
EXPO_PUBLIC_BACKEND_URL=http://localhost:5000

# AI Gateway HTTP and WebSocket endpoint for Gemini Live Stream
EXPO_PUBLIC_AI_GATEWAY_URL=http://localhost:8000
EXPO_PUBLIC_AI_GATEWAY_WS_URL=ws://localhost:8000/api/ai/stream

# Mocks (Useful for emulator/simulator testing where native hardware is restricted)
EXPO_PUBLIC_MOCK_BLE_BEACON=true
EXPO_PUBLIC_MOCK_GPS_MOVEMENT=true
